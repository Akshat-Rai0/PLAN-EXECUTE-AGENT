LANGCHAIN_API_KEY=ls__...your key...
LANGCHAIN_PROJECT=plan-execute-agent
OPENROUTER_API_KEY=  # Required for browser automation with browser-use
BROWSER_USE_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free  # Optional: model for browser automation