ANTHROPIC_API_KEY=
TAVILY_API_KEY=
SANDBOX_TIMEOUT_SECONDS=15
SANDBOX_MAX_MEMORY_MB=256
OUTBOUND_DOMAIN_ALLOWLIST=api.tavily.com
LLM_PROVIDER=groq   # or "ollama" for local dev 
OLLAMA_MODEL= gemma4:latest
CLAUDE_MODEL = claude-sonnet-4.6
GROQ_API_KEY=
GROQ_MODEL = 
